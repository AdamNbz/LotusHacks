# ============================================================
# LotusHacks AI Agent - Environment Variables
# Sao chép file này thành .env và điền các giá trị thực
# ============================================================

# --- LLM API Keys ---
# OpenAI API Key (bắt buộc nếu dùng GPT models)
OPENAI_API_KEY=sk-...

# Qwen API Key (tùy chọn, nếu dùng Qwen model)
QWEN_API_KEY=

# --- Database ---
# MongoDB URI (dùng cho auth module)
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB_NAME=lotushacks

# --- JWT Auth ---
JWT_SECRET=change-me-to-a-strong-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080

# --- Google OAuth ---
GOOGLE_CLIENT_ID=

# --- Agent Config ---
# Model mặc định cho Agent (gpt-4o-mini, gpt-4o, gpt-3.5-turbo...)
AGENT_LLM_MODEL=gpt-4o-mini
AGENT_LLM_TEMPERATURE=0

# --- ChromaDB ---
# Thư mục lưu trữ vectorstore (mặc định: ./app/data/chroma_db)
CHROMA_DB_DIR=./app/data/chroma_db

# --- CORS ---
# Danh sách origins được phép (ngăn cách bằng dấu phẩy)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
